#!/bin/bash
#PBS -P rg42
#PBS -q copyq
#PBS -l walltime=08:00:00
#PBS -l mem=4GB
#PBS -l ncpus=1
#PBS -l jobfs=1GB
#PBS -l storage=gdata/rg42+scratch/rg42
#PBS -l wd
#PBS -N transfer_gadi_to_rds_job

# Usage on Gadi:
#   export SRC_PATH=/scratch/rg42/AGAR/intermediates/2025/B07
#   export RDS_DEST=/rds/PRJ-AGAR/PRJ-AGAR/intermediates/2025/B07
#   export RDS_SFTP_USER=<your_rds_username>
#   # Optional when the RDS server reports "Too many authentication failures":
#   # export RDS_SFTP_IDENTITY_FILE=$HOME/.ssh/<your_private_key>
#   # Optional password mode from a login shell:
#   # export RDS_SFTP_USE_PASSWORD=1
#   # ./scripts/submit_transfer_gadi_to_rds.sh
#   export TRANSFER_SCRIPT=/g/data/rg42/agar-bactopia-pipeline/scripts/transfer_gadi_to_rds.sh
#   export DEBUG_LOG_DIR=/scratch/rg42/${USER}/transfer_logs
#   export RDS_UPLOAD_MANIFEST_DIR=/scratch/rg42/${USER}/.rds_transfer_manifests
#   qsub -V /g/data/rg42/agar-bactopia-pipeline/scripts/jobsubmission_transfer_gadi_to_rds.pbs

set -euo pipefail

script_dir=$(cd "$(dirname "$0")" && pwd)
project_name=${PBS_PROJECT:-${PROJECT:-rg42}}
scratch_user_root="/scratch/${project_name}/${USER}"

DEBUG_LOG_DIR=${DEBUG_LOG_DIR:-${scratch_user_root}/transfer_logs}
mkdir -p "$DEBUG_LOG_DIR"
debug_stamp=${PBS_JOBID:-manual}.$(date '+%Y%m%d_%H%M%S')
DEBUG_RUN_LOG=${DEBUG_RUN_LOG:-$DEBUG_LOG_DIR/transfer_gadi_to_rds.${debug_stamp}.run.log}
RDS_UPLOAD_MANIFEST_DIR=${RDS_UPLOAD_MANIFEST_DIR:-${scratch_user_root}/.rds_transfer_manifests}
KEEP_DEBUG_LOG=${KEEP_DEBUG_LOG:-0}

SRC_PATH=${SRC_PATH:-}
RDS_DEST=${RDS_DEST:-}
RDS_SFTP_USER=${RDS_SFTP_USER:-}
RDS_SFTP_IDENTITY_FILE=${RDS_SFTP_IDENTITY_FILE:-}
RDS_SFTP_PASSWORD_FILE=${RDS_SFTP_PASSWORD_FILE:-}
RDS_SFTP_DELETE_PASSWORD_FILE=${RDS_SFTP_DELETE_PASSWORD_FILE:-0}
RDS_SFTP_OPTS=${RDS_SFTP_OPTS:-}
RDS_SFTP_CHUNK_SIZE=${RDS_SFTP_CHUNK_SIZE:-2000}
RDS_IGNORE_MANIFEST=${RDS_IGNORE_MANIFEST:-0}
RDS_PRIORITIZE_UPLOADS=${RDS_PRIORITIZE_UPLOADS:-1}
RDS_INCLUDE_DIRS=${RDS_INCLUDE_DIRS:-}
RDS_EXCLUDE_DIRS=${RDS_EXCLUDE_DIRS:-_work}
RDS_EXCLUDE_FILES=${RDS_EXCLUDE_FILES:-.nextflow.log,.nextflow.log.*}
RDS_EXCLUDE_PATHS=${RDS_EXCLUDE_PATHS:-}
RDS_COPY_SINCE=${RDS_COPY_SINCE:-}
TRANSFER_SCRIPT=${TRANSFER_SCRIPT:-}

if [[ -z $TRANSFER_SCRIPT ]]; then
  transfer_candidates=(
    "$script_dir/transfer_gadi_to_rds.sh"
  )
  if [[ -n ${PBS_O_WORKDIR:-} ]]; then
    transfer_candidates+=(
      "$PBS_O_WORKDIR/scripts/transfer_gadi_to_rds.sh"
      "$PBS_O_WORKDIR/transfer_gadi_to_rds.sh"
    )
  fi
  transfer_candidates+=(
    "/g/data/${project_name}/agar-bactopia-pipeline/scripts/transfer_gadi_to_rds.sh"
  )
  if [[ $project_name != "rg42" ]]; then
    transfer_candidates+=(
      "/g/data/rg42/agar-bactopia-pipeline/scripts/transfer_gadi_to_rds.sh"
    )
  fi

  for candidate in "${transfer_candidates[@]}"; do
    if [[ -x $candidate ]]; then
      TRANSFER_SCRIPT=$candidate
      break
    fi
  done

  if [[ -z $TRANSFER_SCRIPT ]]; then
    echo "TRANSFER_SCRIPT is not set, and no default helper path was found." >&2
    echo "PBS is running this wrapper from its internal spool directory:" >&2
    echo "  $script_dir" >&2
    if [[ -n ${PBS_O_WORKDIR:-} ]]; then
      echo "PBS_O_WORKDIR was:" >&2
      echo "  $PBS_O_WORKDIR" >&2
    fi
    echo "Tried these helper paths:" >&2
    printf '  %s\n' "${transfer_candidates[@]}" >&2
    echo "Set TRANSFER_SCRIPT explicitly before qsub, for example:" >&2
    echo "  export TRANSFER_SCRIPT=/g/data/rg42/agar-bactopia-pipeline/scripts/transfer_gadi_to_rds.sh" >&2
    exit 1
  fi
fi

mkdir -p "$RDS_UPLOAD_MANIFEST_DIR"

if [[ -z $SRC_PATH || -z $RDS_DEST || -z $RDS_SFTP_USER ]]; then
  echo "SRC_PATH, RDS_DEST, and RDS_SFTP_USER must be set before submitting this PBS job." >&2
  echo "Use exported variables followed by qsub -V, for example:" >&2
  echo "  export SRC_PATH=/scratch/rg42/AGAR/intermediates/2025/B07" >&2
  echo "  export RDS_DEST=/rds/PRJ-AGAR/PRJ-AGAR/intermediates/2025/B07" >&2
  echo "  export RDS_SFTP_USER=<your_rds_username>" >&2
  echo "  qsub -V $script_dir/jobsubmission_transfer_gadi_to_rds.pbs" >&2
  exit 1
fi

if [[ ! -d $SRC_PATH ]]; then
  echo "Source folder not found: $SRC_PATH" >&2
  exit 1
fi

if [[ ! -x $TRANSFER_SCRIPT ]]; then
  echo "Transfer script not found or not executable: $TRANSFER_SCRIPT" >&2
  echo "Set TRANSFER_SCRIPT to the real helper path before qsub." >&2
  exit 1
fi

echo "Transfer job settings:"
echo "  PBS_JOBID=${PBS_JOBID:-<unset>}"
echo "  PBS_O_WORKDIR=${PBS_O_WORKDIR:-<unset>}"
echo "  DEBUG_RUN_LOG=$DEBUG_RUN_LOG"
echo "  DEBUG_LOG_DIR=$DEBUG_LOG_DIR"
echo "  RDS_UPLOAD_MANIFEST_DIR=$RDS_UPLOAD_MANIFEST_DIR"
echo "  KEEP_DEBUG_LOG=$KEEP_DEBUG_LOG"
echo "  SRC_PATH=$SRC_PATH"
echo "  RDS_DEST=$RDS_DEST"
echo "  RDS_SFTP_USER=$RDS_SFTP_USER"
if [[ -n $RDS_SFTP_PASSWORD_FILE ]]; then
  echo "  SFTP_AUTH_MODE=password file"
else
  echo "  RDS_SFTP_IDENTITY_FILE=${RDS_SFTP_IDENTITY_FILE:-<default ssh selection>}"
fi
echo "  RDS_SFTP_CHUNK_SIZE=$RDS_SFTP_CHUNK_SIZE"
echo "  RDS_IGNORE_MANIFEST=$RDS_IGNORE_MANIFEST"
echo "  RDS_PRIORITIZE_UPLOADS=$RDS_PRIORITIZE_UPLOADS"
echo "  RDS_INCLUDE_DIRS=${RDS_INCLUDE_DIRS:-<none>}"
echo "  RDS_EXCLUDE_DIRS=${RDS_EXCLUDE_DIRS:-<none>}"
echo "  RDS_EXCLUDE_FILES=${RDS_EXCLUDE_FILES:-<none>}"
echo "  RDS_EXCLUDE_PATHS=${RDS_EXCLUDE_PATHS:-<none>}"
echo "  RDS_COPY_SINCE=${RDS_COPY_SINCE:-<all files>}"
echo "  TRANSFER_SCRIPT=$TRANSFER_SCRIPT"
echo "  Wrapper log directory contents:"
ls -ld "$DEBUG_LOG_DIR"
echo "  Manifest directory contents:"
ls -ld "$RDS_UPLOAD_MANIFEST_DIR"

set +e
RDS_UPLOAD_MANIFEST_DIR="$RDS_UPLOAD_MANIFEST_DIR" \
RDS_SFTP_USER="$RDS_SFTP_USER" \
RDS_SFTP_IDENTITY_FILE="$RDS_SFTP_IDENTITY_FILE" \
RDS_SFTP_PASSWORD_FILE="$RDS_SFTP_PASSWORD_FILE" \
RDS_SFTP_OPTS="$RDS_SFTP_OPTS" \
RDS_SFTP_CHUNK_SIZE="$RDS_SFTP_CHUNK_SIZE" \
RDS_IGNORE_MANIFEST="$RDS_IGNORE_MANIFEST" \
RDS_PRIORITIZE_UPLOADS="$RDS_PRIORITIZE_UPLOADS" \
RDS_INCLUDE_DIRS="$RDS_INCLUDE_DIRS" \
RDS_EXCLUDE_DIRS="$RDS_EXCLUDE_DIRS" \
RDS_EXCLUDE_FILES="$RDS_EXCLUDE_FILES" \
RDS_EXCLUDE_PATHS="$RDS_EXCLUDE_PATHS" \
RDS_COPY_SINCE="$RDS_COPY_SINCE" \
  bash -x "$TRANSFER_SCRIPT" "$SRC_PATH" "$RDS_DEST" >"$DEBUG_RUN_LOG" 2>&1
transfer_exit_code=$?
set -e

if [[ $RDS_SFTP_DELETE_PASSWORD_FILE == 1 && -n $RDS_SFTP_PASSWORD_FILE && -f $RDS_SFTP_PASSWORD_FILE ]]; then
  rm -f "$RDS_SFTP_PASSWORD_FILE"
  echo "Removed temporary password file"
fi

echo "Transfer helper exit code: $transfer_exit_code"
echo "Transfer helper log: $DEBUG_RUN_LOG"
if [[ $transfer_exit_code -ne 0 && -f $DEBUG_RUN_LOG ]]; then
  echo "Last 40 lines of transfer helper log:"
  tail -n 40 "$DEBUG_RUN_LOG"
fi

if [[ $transfer_exit_code -eq 0 && $KEEP_DEBUG_LOG != 1 && -f $DEBUG_RUN_LOG ]]; then
  rm -f "$DEBUG_RUN_LOG"
  echo "Removed successful transfer helper log: $DEBUG_RUN_LOG"
fi

exit "$transfer_exit_code"
