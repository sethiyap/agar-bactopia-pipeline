process {
  executor = 'pbspro'
  queue = 'normal'
  cpus = 1
  memory = 4.GB
  time = 4.h
  maxForks = 8
  clusterOptions = { "-P rg42 -l ncpus=${task.cpus},mem=${task.memory.toMega()}mb,walltime=04:00:00,storage=scratch/rg42+gdata/rg42" }

  beforeScript = '''
module purge
module load singularity
'''

  withName: 'FIMTYPER' {
    container = '/g/data/rg42/bactopia/caches/singularity/fimtyper.sif'
  }
}

executor {
  queueSize = 8
}

singularity {
  enabled = true
  autoMounts = true
  cacheDir = '/g/data/rg42/bactopia/caches/singularity'
  pullTimeout = '2h'
}

params {
  max_memory = 4.GB
  max_cpus = 1
  max_time = 4.h
}

