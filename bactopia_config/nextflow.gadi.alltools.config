def kleborateCompatScript = System.getenv('KLEBORATE_COMPAT_SCRIPT') ?: '/home/562/ps1744/agar_bactopia_test/scripts/kleborate_232_compat.sh'

def commonBeforeScript = '''
module purge
module load singularity

export TERM="${TERM:-dumb}"
export SINGULARITYENV_TERM=dumb
'''

process {
  executor = 'pbspro'
  queue = 'normal'
  cpus = 4
  memory = 16.GB
  time = 12.h
  maxForks = 4
  clusterOptions = { "-P rg42 -l ncpus=${task.cpus},mem=${task.memory.toMega()}mb,walltime=12:00:00,storage=scratch/rg42+gdata/rg42" }

  beforeScript = commonBeforeScript

  withName: /.*:MLST_MODULE/ {
    container = '/scratch/rg42/ps1744/singularity_cache/mlst-2.33.1--hdfd78af_0.sif'
  }

  withName: 'BACTOPIATOOLS:KLEBORATE:KLEBORATE_MODULE' {
    container = '/scratch/rg42/ps1744/singularity_cache/kleborate-2.3.2--pyhdfd78af_0.img'
    beforeScript = commonBeforeScript + """
if [[ ! -f "${kleborateCompatScript}" ]]; then
  echo "KLEBORATE_COMPAT_SCRIPT not found: ${kleborateCompatScript}" >&2
  exit 1
fi

cp "${kleborateCompatScript}" ./kleborate
chmod +x ./kleborate

if [[ -f .command.sh ]]; then
  perl -0pi -e 's{(?<![./])\\bkleborate\\b}{./kleborate}g' .command.sh
fi

export KLEBORATE_REAL="/usr/local/bin/kleborate"
export SINGULARITYENV_KLEBORATE_REAL="/usr/local/bin/kleborate"
export PATH="$PWD:$PATH"
export SINGULARITYENV_PREPEND_PATH="\$PWD"

echo "HOST pwd: \$PWD" >&2
ls -l ./kleborate .command.sh >&2 || true
grep -n 'kleborate' .command.sh >&2 || true
"""
  }
withName: /.*:CHECKM:CHECKM_LINEAGEWF/ {
    cpus = 4
    memory = 32.GB
    time = 24.h
    clusterOptions = { "-P rg42 -l ncpus=${task.cpus},mem=${task.memory.toMega()}mb,walltime=24:00:00,jobfs=1GB,storage=scratch/rg42+gdata/rg42" }
    beforeScript = commonBeforeScript + """
export MPLCONFIGDIR="\${PWD}/.mplconfig"
mkdir -p "\$MPLCONFIGDIR"
"""
  }
}

executor {
  queueSize = 8
}

singularity {
  enabled = true
  autoMounts = true
  cacheDir = '/scratch/rg42/ps1744/singularity_cache'
  pullTimeout = '2h'
}

params {
  max_memory = 16.GB
  max_cpus = 4
  max_time = 12.h
}

