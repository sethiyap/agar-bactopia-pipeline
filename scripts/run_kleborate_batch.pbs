#!/bin/bash
#PBS -P rg42
#PBS -q normal
#PBS -l walltime=24:00:00
#PBS -l ncpus=8
#PBS -l mem=32GB
#PBS -l jobfs=100GB
#PBS -l storage=scratch/rg42+gdata/rg42
#PBS -N kleborate_batch
#PBS -l wd

set -euo pipefail

# Dedicated Kleborate runner for one Bactopia batch.
# Keep this separate from the generic extra-tools wrapper because Kleborate
# requires a version-specific compatibility config and script.

PROJECT=${PROJECT:-rg42}
USER_NAME=${USER_NAME:-$USER}
RUN_AGAR_ROOT=${RUN_AGAR_ROOT:-/home/562/${USER_NAME}/run_AGAR}

BASE_DIR=${BASE_DIR:-/g/data/${PROJECT}/${USER_NAME}/agar_bactopia_test}
RESULTS_MAIN=${RESULTS_MAIN:-}

SING_CACHE=${SING_CACHE:-/scratch/${PROJECT}/${USER_NAME}/singularity_cache}
DATASETS_CACHE=${DATASETS_CACHE:-/g/data/${PROJECT}/bactopia_datasets/bactopia_datasets_custom}
NEXTFLOW_CONFIG=${NEXTFLOW_CONFIG:-${RUN_AGAR_ROOT}/bactopia_config/nextflow.gadi.alltools.config}
KLEBORATE_COMPAT_SCRIPT=${KLEBORATE_COMPAT_SCRIPT:-${RUN_AGAR_ROOT}/scripts/kleborate_232_compat.sh}
BACTOPIA_PIPELINE=${BACTOPIA_PIPELINE:-/g/data/${PROJECT}/bactopia/bactopia}

RUN_LABEL=${RUN_LABEL:-kleborate_${PBS_JOBID}}
RESULTS_ROOT=${RESULTS_ROOT:-/scratch/${PROJECT}/${USER_NAME}/bactopia_results}
RESULTS_OUT=${RESULTS_OUT:-${GDATA_OUT:-${RESULTS_ROOT}/${RUN_LABEL}}}
WORK_ROOT=${WORK_ROOT:-${RESULTS_ROOT}/_work/bactopia_kleborate/${RUN_LABEL}}
SCRATCH_ROOT=${SCRATCH_ROOT:-$WORK_ROOT}
SCRATCH_RUN=${SCRATCH_ROOT}
INCLUDE_FILE=${INCLUDE_FILE:-}

mkdir -p "$SCRATCH_RUN" "$RESULTS_OUT" "$SING_CACHE"

if [[ -z "$RESULTS_MAIN" ]]; then
  echo "RESULTS_MAIN is required." >&2
  exit 1
fi

if [[ ! -d "$RESULTS_MAIN" ]]; then
  echo "RESULTS_MAIN not found: $RESULTS_MAIN" >&2
  exit 1
fi

if [[ ! -f "$NEXTFLOW_CONFIG" ]]; then
  echo "NEXTFLOW_CONFIG not found: $NEXTFLOW_CONFIG" >&2
  exit 1
fi

if [[ ! -f "$KLEBORATE_COMPAT_SCRIPT" ]]; then
  echo "KLEBORATE_COMPAT_SCRIPT not found: $KLEBORATE_COMPAT_SCRIPT" >&2
  exit 1
fi

module purge
module load nextflow
module load singularity

export NXF_HOME="$SCRATCH_RUN/.nextflow"
export NXF_WORK="$SCRATCH_RUN/work"
export NXF_SINGULARITY_CACHEDIR="$SING_CACHE"
export SINGULARITY_CACHEDIR="$SING_CACHE"
export KLEBORATE_COMPAT_SCRIPT
mkdir -p "$NXF_HOME" "$NXF_WORK" "$NXF_SINGULARITY_CACHEDIR"
mkdir -p "$RESULTS_OUT/results_kleborate"

cd "$SCRATCH_RUN"

cmd=(
  nextflow run "$BACTOPIA_PIPELINE"
  --bactopia "$RESULTS_MAIN"
  --wf kleborate
  --datasets_cache "$DATASETS_CACHE"
  --outdir "$RESULTS_OUT/results_kleborate"
  -profile singularity
  -work-dir "${NXF_WORK}/kleborate"
  -c "$NEXTFLOW_CONFIG"
  -resume
)

if [[ -n "$INCLUDE_FILE" ]]; then
  cmd+=(--include "$INCLUDE_FILE")
fi

"${cmd[@]}"

rsync -av .nextflow.log* "$RESULTS_OUT/" || true
