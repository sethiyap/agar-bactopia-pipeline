#!/bin/bash
#PBS -P rg42
#PBS -q normal
#PBS -l walltime=48:00:00
#PBS -l ncpus=8
#PBS -l mem=32GB
#PBS -l jobfs=100GB
#PBS -l storage=scratch/rg42+gdata/rg42
#PBS -N bactopia_tools
#PBS -l wd

set -euo pipefail

# Batch runner for non-Kleborate Bactopia tool workflows on an existing
# results_main directory.
# Edit the variables in the "User settings" section before submitting with qsub.
#
# Example:
#   qsub -v RESULTS_MAIN=/path/to/results_main,RUN_LABEL=batch_bactopia_001_tools scripts/run_extra_bactopia_tools.pbs

###############################################################################
# User settings
###############################################################################
PROJECT=${PROJECT:-rg42}
USER_NAME=${USER_NAME:-$USER}

# Existing main Bactopia results directory.
BASE_DIR=${BASE_DIR:-/g/data/${PROJECT}/${USER_NAME}/agar_bactopia_test}
RESULTS_MAIN=${RESULTS_MAIN:-}

# Shared caches/config.
SING_CACHE=${SING_CACHE:-/scratch/${PROJECT}/${USER_NAME}/singularity_cache}
DATASETS_CACHE=${DATASETS_CACHE:-/g/data/${PROJECT}/bactopia_datasets_custom}
NEXTFLOW_CONFIG=${NEXTFLOW_CONFIG:-${BASE_DIR}/scripts/nextflow.gadi.all_tools.config}
BACTOPIA_PIPELINE=${BACTOPIA_PIPELINE:-/g/data/${PROJECT}/bactopia/bactopia}

# Output root for these extra tool runs.
RUN_LABEL=${RUN_LABEL:-extra_tools_${PBS_JOBID}}
RESULTS_ROOT=${RESULTS_ROOT:-/scratch/${PROJECT}/${USER_NAME}/bactopia_results}
RESULTS_OUT=${RESULTS_OUT:-${GDATA_OUT:-${RESULTS_ROOT}/${RUN_LABEL}}}
WORK_ROOT=${WORK_ROOT:-${RESULTS_ROOT}/_work/bactopia_tools/${RUN_LABEL}}
SCRATCH_ROOT=${SCRATCH_ROOT:-$WORK_ROOT}
SCRATCH_RUN=${SCRATCH_ROOT}

# Tools to run. Keep only the ones you need. This default matches the main
# pipeline's default non-Kleborate bundle.
TOOLS_STRING=${TOOLS_STRING:-abritamr amrfinderplus bracken checkm mlst plasmidfinder}

# Optional sample include file. Leave empty to process all samples in RESULTS_MAIN.
INCLUDE_FILE=${INCLUDE_FILE:-}

# Tool-specific parameters. Only set the ones you need.
MYKROBE_SPECIES=${MYKROBE_SPECIES:-}
KRAKEN2_DB=${KRAKEN2_DB:-}
DEFENSEFINDER_DB=${DEFENSEFINDER_DB:-}
###############################################################################

mkdir -p "$SCRATCH_RUN" "$RESULTS_OUT" "$SING_CACHE"

cd "$SCRATCH_RUN"

module purge
module load nextflow
module load singularity

export NXF_HOME="$SCRATCH_RUN/.nextflow"
export NXF_WORK="$SCRATCH_RUN/work"
export NXF_SINGULARITY_CACHEDIR="$SING_CACHE"
export SINGULARITY_CACHEDIR="$SING_CACHE"
mkdir -p "$NXF_HOME" "$NXF_WORK" "$NXF_SINGULARITY_CACHEDIR"

if [[ -z "$RESULTS_MAIN" ]]; then
  echo "RESULTS_MAIN is required." >&2
  exit 1
fi

if [[ ! -d "$RESULTS_MAIN" ]]; then
  echo "RESULTS_MAIN not found: $RESULTS_MAIN" >&2
  exit 1
fi

if [[ ! -f "$NEXTFLOW_CONFIG" ]]; then
  echo "NEXTFLOW_CONFIG not found: $NEXTFLOW_CONFIG" >&2
  exit 1
fi

COMMON_ARGS=(
  --bactopia "$RESULTS_MAIN"
  --datasets_cache "$DATASETS_CACHE"
  -profile singularity
  -c "$NEXTFLOW_CONFIG"
)

# shellcheck disable=SC2206
TOOLS=(${TOOLS_STRING})

if [[ -n "${INCLUDE_FILE}" ]]; then
  COMMON_ARGS+=(--include "$INCLUDE_FILE")
fi

for tool in "${TOOLS[@]}"; do
  TOOL_OUTDIR="results_${tool}"
  TOOL_WORKDIR="${NXF_WORK}/${tool}"
  EXTRA_ARGS=()

  case "$tool" in
    mykrobe)
      if [[ -z "${MYKROBE_SPECIES}" ]]; then
        echo "Skipping mykrobe: set MYKROBE_SPECIES first." >&2
        continue
      fi
      EXTRA_ARGS+=(--mykrobe_species "$MYKROBE_SPECIES")
      ;;
    kraken2|bracken)
      if [[ -z "${KRAKEN2_DB}" ]]; then
        echo "Skipping ${tool}: set KRAKEN2_DB first." >&2
        continue
      fi
      EXTRA_ARGS+=(--kraken2_db "$KRAKEN2_DB")
      ;;
    defensefinder)
      if [[ -n "${DEFENSEFINDER_DB}" ]]; then
        EXTRA_ARGS+=(--defensefinder_db "$DEFENSEFINDER_DB")
      fi
      ;;
  esac

  if [[ "$tool" == "kleborate" ]]; then
    echo "Skipping kleborate in run_extra_bactopia_tools.pbs; use run_kleborate_batch.pbs instead." >&2
    continue
  fi

  echo "Running ${tool}"
  nextflow run "$BACTOPIA_PIPELINE" \
    --wf "$tool" \
    "${COMMON_ARGS[@]}" \
    --outdir "$TOOL_OUTDIR" \
    -work-dir "$TOOL_WORKDIR" \
    -resume \
    "${EXTRA_ARGS[@]}"

  rsync -av "${TOOL_OUTDIR}/" "${RESULTS_OUT}/${TOOL_OUTDIR}/"
done

if compgen -G ".nextflow.log*" > /dev/null; then
  rsync -av .nextflow.log* "$RESULTS_OUT/"
fi
