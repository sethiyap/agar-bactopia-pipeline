def kleborateCompatScript = System.getenv('KLEBORATE_COMPAT_SCRIPT') ?: "${baseDir}/scripts/kleborate_232_compat.sh"
def singCache = System.getenv('SING_CACHE') ?: "/scratch/rg42/${System.getenv('USER') ?: 'unknown'}/singularity_cache"
def mlstContainer = System.getenv('MLST_CONTAINER') ?: "${singCache}/mlst-2.33.1--hdfd78af_0.sif"
def kleborateContainer = System.getenv('KLEBORATE_CONTAINER') ?: "${singCache}/kleborate-2.3.2--pyhdfd78af_0.img"

def commonBeforeScript = '''
module purge
module load singularity

export TERM="${TERM:-dumb}"
export SINGULARITYENV_TERM=dumb
'''

process {
  executor = 'pbspro'
  queue = 'normal'
  cpus = 4
  memory = 16.GB
  time = 12.h
  maxForks = 4
  clusterOptions = { "-P rg42 -l ncpus=${task.cpus},mem=${task.memory.toMega()}mb,walltime=12:00:00,jobfs=1GB,storage=scratch/rg42+gdata/rg42" }

  beforeScript = commonBeforeScript

  withName: /.*:ASSEMBLER/ {
    cpus = 4
    memory = 32.GB
    time = 24.h
    clusterOptions = { "-P rg42 -l ncpus=${task.cpus},mem=${task.memory.toMega()}mb,walltime=24:00:00,jobfs=1GB,storage=scratch/rg42+gdata/rg42" }
  }

  withName: /.*:MLST_MODULE/ {
    container = mlstContainer
  }

  withName: /.*:KLEBORATE_MODULE/ {
    container = kleborateContainer
    beforeScript = commonBeforeScript + """
if [[ ! -f "${kleborateCompatScript}" ]]; then
  echo "KLEBORATE_COMPAT_SCRIPT not found: ${kleborateCompatScript}" >&2
  exit 1
fi

cp "${kleborateCompatScript}" ./kleborate
chmod +x ./kleborate

if [[ -f .command.sh ]]; then
  perl -0pi -e 's{(?<![./])\\bkleborate\\b}{./kleborate}g' .command.sh
fi

export KLEBORATE_REAL="/usr/local/bin/kleborate"
export SINGULARITYENV_KLEBORATE_REAL="/usr/local/bin/kleborate"
export PATH="$PWD:$PATH"
export SINGULARITYENV_PREPEND_PATH="\$PWD"

echo "HOST pwd: \$PWD" >&2
ls -l ./kleborate .command.sh >&2 || true
grep -n 'kleborate' .command.sh >&2 || true
"""
  }

  withName: /.*:CHECKM:CHECKM_LINEAGEWF/ {
    cpus = 4
    memory = 32.GB
    time = 24.h
    clusterOptions = { "-P rg42 -l ncpus=${task.cpus},mem=${task.memory.toMega()}mb,walltime=24:00:00,jobfs=1GB,storage=scratch/rg42+gdata/rg42" }
    beforeScript = commonBeforeScript + """
export MPLCONFIGDIR="\${PWD}/.mplconfig"
mkdir -p "\$MPLCONFIGDIR"

if [[ -f .command.sh ]]; then
  python - <<'PY'
from pathlib import Path
path = Path('.command.sh')
text = path.read_text()
text = text.replace(
    'find ./results/ -name "*.faa" -or -name "*hmmer.analyze.txt" -or -name "*.fasta" | xargs gzip',
    'find ./results/ \\\\( -name "*.faa" -o -name "*hmmer.analyze.txt" -o -name "*.fasta" \\\\) -print0 | xargs -0 -r gzip || true'
)
text = text.replace('mv results/checkm.log ./', 'mv results/checkm.log ./ || true')
text = text.replace(
    'checkm: $(echo $(checkm -h 2>&1) | sed \\'s/.*CheckM v//;s/ .*\\$//\\')',
    'checkm: $( (checkm -h 2>&1 || true) | sed \\'s/.*CheckM v//;s/ .*\\$//\\')'
)
path.write_text(text)
PY
fi
"""
  }
}

executor {
  queueSize = 8
}

singularity {
  enabled = true
  autoMounts = true
  cacheDir = singCache
  pullTimeout = '2h'
}

params {
  max_memory = 32.GB
  max_cpus = 4
  max_time = 12.h
}
