#!/usr/bin/env bash

# Copy to config/sites/slurm.local.env.
# Edit these defaults for your non-Gadi Slurm site.

PROJECT=${PROJECT:-local}
USER_NAME=${USER_NAME:-$USER}

PIPELINE_ROOT=${PIPELINE_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}

RUN_AGAR_DIR=${RUN_AGAR_DIR:-$PIPELINE_ROOT}
BACTOPIA_PIPELINE=${BACTOPIA_PIPELINE:-/path/to/bactopia}
DATASETS_CACHE=${DATASETS_CACHE:-/path/to/bactopia_datasets_custom}
KRAKEN2_DB=${KRAKEN2_DB:-/path/to/kraken2_db}

NEXTFLOW_CONFIG=${NEXTFLOW_CONFIG:-$PIPELINE_ROOT/scripts/nextflow.slurm.all_tools.config}
KLEBORATE_COMPAT_SCRIPT=${KLEBORATE_COMPAT_SCRIPT:-$PIPELINE_ROOT/scripts/kleborate_232_compat.sh}
FIMTYPER_PIPELINE=${FIMTYPER_PIPELINE:-$PIPELINE_ROOT/bactopia_config/fimtyper.nf}
FIMTYPER_CONFIG=${FIMTYPER_CONFIG:-$PIPELINE_ROOT/bactopia_config/fimtyper.slurm.config}
MERGE_FIMTYPER_SCRIPT=${MERGE_FIMTYPER_SCRIPT:-$PIPELINE_ROOT/scripts/merge_fimtyper_summary.sh}
MINIFORGE_ROOT=${MINIFORGE_ROOT:-$PIPELINE_ROOT/.local/miniforge3}
MLST_ENV=${MLST_ENV:-$PIPELINE_ROOT/.local/mlst_env}

RESULTS_ROOT_DEFAULT=${RESULTS_ROOT_DEFAULT:-/scratch/${USER_NAME}/custom_bactopia_runs}
SING_CACHE=${SING_CACHE:-/scratch/${USER_NAME}/singularity_cache}
BASE_DIR=${BASE_DIR:-${PIPELINE_ROOT}}
CHECK_INODE_QUOTA=${CHECK_INODE_QUOTA:-0}

# Optional Slurm site settings consumed by the Slurm Nextflow config.
SLURM_PARTITION=${SLURM_PARTITION:-}
SLURM_ACCOUNT=${SLURM_ACCOUNT:-}
SLURM_CLUSTER_OPTIONS=${SLURM_CLUSTER_OPTIONS:-}
