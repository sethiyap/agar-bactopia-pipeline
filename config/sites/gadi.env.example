#!/usr/bin/env bash

# Copy to config/sites/gadi.local.env.
# These defaults match the current AGAR/Gadi setup used for B07.

PROJECT=${PROJECT:-rg42}
USER_NAME=${USER_NAME:-$USER}

PIPELINE_ROOT=${PIPELINE_ROOT:-/g/data/${PROJECT}/agar-bactopia-pipeline}

# Shared Gadi install and data locations.
RUN_AGAR_DIR=${RUN_AGAR_DIR:-$PIPELINE_ROOT}
BACTOPIA_PIPELINE=${BACTOPIA_PIPELINE:-/g/data/${PROJECT}/bactopia/bactopia}
DATASETS_CACHE=${DATASETS_CACHE:-/g/data/${PROJECT}/bactopia_datasets/bactopia_datasets_custom}
KRAKEN2_DB=${KRAKEN2_DB:-/g/data/${PROJECT}/bactopia/kraken_indices/k2_pluspf_16_GB_20251015}

# Shared configs and helpers currently in use on Gadi.
NEXTFLOW_CONFIG=${NEXTFLOW_CONFIG:-$PIPELINE_ROOT/bactopia_config/nextflow.gadi.alltools.config}
KLEBORATE_COMPAT_SCRIPT=${KLEBORATE_COMPAT_SCRIPT:-$PIPELINE_ROOT/scripts/kleborate_232_compat.sh}
FIMTYPER_PIPELINE=${FIMTYPER_PIPELINE:-$PIPELINE_ROOT/bactopia_config/fimtyper.nf}
FIMTYPER_CONFIG=${FIMTYPER_CONFIG:-$PIPELINE_ROOT/bactopia_config/fimtyper.gadi.config}
MERGE_FIMTYPER_SCRIPT=${MERGE_FIMTYPER_SCRIPT:-$PIPELINE_ROOT/scripts/merge_fimtyper_summary.sh}
MINIFORGE_ROOT=${MINIFORGE_ROOT:-/g/data/${PROJECT}/bactopia_datasets/miniforge3}
MLST_ENV=${MLST_ENV:-/g/data/${PROJECT}/bactopia_datasets/envs/mlst_env}

# Scheduler/site defaults.
RESULTS_ROOT_DEFAULT=${RESULTS_ROOT_DEFAULT:-/scratch/${PROJECT}/${USER_NAME}/custom_bactopia_runs}
SING_CACHE=${SING_CACHE:-/scratch/${PROJECT}/${USER_NAME}/singularity_cache}
BASE_DIR=${BASE_DIR:-${PIPELINE_ROOT}}
CHECK_INODE_QUOTA=${CHECK_INODE_QUOTA:-1}
INODE_FS_WARN_FREE_PCT=${INODE_FS_WARN_FREE_PCT:-15}
INODE_FS_MIN_FREE_COUNT=${INODE_FS_MIN_FREE_COUNT:-50000}
INODE_FS_MIN_FREE_PCT=${INODE_FS_MIN_FREE_PCT:-5}
PROJECT_INODE_WARN_USE_PCT=${PROJECT_INODE_WARN_USE_PCT:-85}
PROJECT_INODE_MAX_USE_PCT=${PROJECT_INODE_MAX_USE_PCT:-95}
