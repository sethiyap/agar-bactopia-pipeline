def kleborateCompatScript = System.getenv('KLEBORATE_COMPAT_SCRIPT')
def singCache = System.getenv('SING_CACHE') ?: "/scratch/rg42/${System.getenv('USER') ?: 'unknown'}/singularity_cache"
def kleborateContainer = System.getenv('KLEBORATE_CONTAINER') ?: "${singCache}/kleborate-2.3.2--pyhdfd78af_0.img"

process {
  withName: /.*KLEBORATE.*/ {
    container = kleborateContainer
    beforeScript = """
      if [[ -z "${kleborateCompatScript}" ]]; then
        echo "KLEBORATE_COMPAT_SCRIPT is not set" >&2
        exit 1
      fi
      export KLEBORATE_REAL="\$(command -v kleborate)"
      cp "${kleborateCompatScript}" ./kleborate
      chmod +x ./kleborate
      export PATH="\$PWD:\$PATH"
    """
  }
}
