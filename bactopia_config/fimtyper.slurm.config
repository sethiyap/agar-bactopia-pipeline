process {
  executor = 'slurm'
  if (System.getenv('SLURM_PARTITION')) {
    queue = System.getenv('SLURM_PARTITION')
  }
  cpus = 1
  memory = 4.GB
  time = 4.h
  maxForks = 8
  if (System.getenv('SLURM_ACCOUNT') || System.getenv('SLURM_CLUSTER_OPTIONS')) {
    clusterOptions = {
      [
        System.getenv('SLURM_ACCOUNT') ? "--account ${System.getenv('SLURM_ACCOUNT')}" : '',
        System.getenv('SLURM_CLUSTER_OPTIONS') ?: ''
      ].findAll { it }.join(' ')
    }
  }

  beforeScript = '''
export TERM="${TERM:-dumb}"
export SINGULARITYENV_TERM=dumb
'''

  withName: 'FIMTYPER' {
    container = System.getenv('FIMTYPER_CONTAINER') ?: '/g/data/rg42/bactopia/caches/singularity/fimtyper.sif'
  }
}

executor {
  queueSize = 8
}

singularity {
  enabled = true
  autoMounts = true
  cacheDir = System.getenv('SING_CACHE') ?: '/tmp'
  pullTimeout = '2h'
}

params {
  max_memory = 4.GB
  max_cpus = 1
  max_time = 4.h
}
