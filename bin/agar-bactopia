#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ./bin/agar-bactopia submit gadi RAW_FASTQ_DIR METADATA_DIR RESULTS_ROOT [BATCH_SIZE]
  ./bin/agar-bactopia submit gadi --additional-tools yes RAW_FASTQ_DIR METADATA_DIR RESULTS_ROOT [BATCH_SIZE]
EOF
}

bin_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
project_root=$(cd "$bin_dir/.." && pwd)

if [[ $# -lt 2 ]]; then
  usage >&2
  exit 1
fi

command=$1
backend=$2
shift 2

case "$command:$backend" in
  submit:gadi)
    exec "$project_root/wrappers/submit.gadi.sh" "$@"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
